style.css
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: Arial, sans-serif;
    background: #0b0f14;
    color: white;
    line-height: 1.6;
}

header {
    padding: 20px 40px;
    display: flex;
    justify-content: center;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(10px);
}

header h2 {
    color: #00ff88;
    font-size: 20px;
    letter-spacing: 2px;
}

.hero {
    height: 90vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 20px;
}

.hero h1 {
    font-size: 48px;
    color: #ffffff;
    max-width: 700px;
}

.hero p {
    font-size: 18px;
    color: #b0b0b0;
    margin-top: 15px;
    margin-bottom: 30px;
    max-width: 500px;
}

button {
    padding: 14px 28px;
    font-size: 16px;
    background: linear-gradient(135deg, #00ff88, #00c96a);
    border: none;
    border-radius: 10px;
    cursor: pointer;
    color: black;
    font-weight: bold;
    transition: 0.3s;
}

button:hover {
    transform: scale(1.05);
}

.about {
    padding: 100px 20px;
    text-align: center;
    background: #0f141b;
}

.about h2 {
    font-size: 32px;
    color: #00ff88;
    margin-bottom: 20px;
}

.about p {
    font-size: 18px;
    color: #b0b0b0;
    max-width: 700px;
    margin: 0 auto;
}
